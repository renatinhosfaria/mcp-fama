# ============================================================
# Configuração do Servidor HTTP
# ============================================================

# Porta do servidor (padrão: 3200)
PORT=3200

# API Key para autenticação Bearer (gere com: openssl rand -hex 32)
API_KEY=

# Rate limit: requisições por minuto (padrão: 60)
RATE_LIMIT_RPM=60

# ============================================================
# Meta Marketing API Credentials
# Obtenha em: https://developers.facebook.com/apps/

# Token de acesso de longa duração (System User Token recomendado para produção)
# Permissões necessárias: ads_management, ads_read, business_management, read_insights
META_ACCESS_TOKEN=

# ID da conta de anúncio padrão (formato: act_XXXXXXXXXX)
# Encontre em: Meta Business Manager > Configurações > Contas de Anúncio
META_AD_ACCOUNT_ID=act_

# ID do app registrado no Meta Developers
META_APP_ID=

# Secret do app (Meta Developers > Configurações Básicas)
META_APP_SECRET=

# Versão da Graph API (padrão: v21.0)
META_API_VERSION=v21.0

# ID do Business Manager (opcional, para listar contas vinculadas)
META_BUSINESS_ID=
